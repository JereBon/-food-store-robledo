# Backend
ENV=dev

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/food_store
SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=TEST-your-access-token-here
MERCADOPAGO_PUBLIC_KEY=TEST-your-public-key-here

# URLs (use ngrok for real MP webhooks, localhost for simulation)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Comma-separated (dev)
CORS_ORIGINS=http://localhost:5173

# Seed admin
SEED_ADMIN_EMAIL=admin@foodstore.local
SEED_ADMIN_PASSWORD=admin123
